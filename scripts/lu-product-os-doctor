#!/usr/bin/env bash
# lu-product-os-doctor — idempotent setup, check, and repair for a project repo.
#
# Setup, check, and repair are the same command:
#   lu-product-os-doctor            check everything, repair what it safely can
#   lu-product-os-doctor --quick    read-only check (~seconds); prints the
#                                   machinery banner agents show at session start
#
# Run from the root of a project repo. Requires: git, gh (authenticated), jq.
# Env override: LU_PRODUCT_OS_REPO=owner/name   (default: <origin owner>/lu-product-os)

set -uo pipefail

QUICK=false
[ "${1:-}" = "--quick" ] && QUICK=true

BOLD=$(tput bold 2>/dev/null || true); RESET=$(tput sgr0 2>/dev/null || true)
declare -a REPORT
STATUS_WORST=0   # 0=full, 1=partial, 2=none

note()   { REPORT+=("OK     $1"); }
fixed()  { REPORT+=("FIXED  $1"); }
warn()   { REPORT+=("WARN   $1"); [ $STATUS_WORST -lt 1 ] && STATUS_WORST=1; }
fail()   { REPORT+=("FAIL   $1"); STATUS_WORST=2; }

# ---------- 0. Preconditions ----------
command -v gh >/dev/null || { echo "gh CLI is required (https://cli.github.com)"; exit 1; }
command -v jq >/dev/null || { echo "jq is required"; exit 1; }

# ---------- 0b. Self-install on PATH ----------
# Non-interactive shells don't source rc files, so "the very first protocol
# step" (running this script) must resolve without PATH setup. A symlink in a
# standard bin dir fixes that for interactive AND non-interactive shells.
if ! $QUICK && ! command -v lu-product-os-doctor >/dev/null 2>&1; then
  SELF="$(cd "$(dirname "${BASH_SOURCE[0]}")" >/dev/null 2>&1 && pwd)/$(basename "${BASH_SOURCE[0]}")"
  for BIN in /usr/local/bin "$HOME/.local/bin"; do
    mkdir -p "$BIN" 2>/dev/null || true
    [ -d "$BIN" ] && [ -w "$BIN" ] || continue
    if ln -sf "$SELF" "$BIN/lu-product-os-doctor" 2>/dev/null; then
      fixed "installed on PATH: $BIN/lu-product-os-doctor -> $SELF"
      break
    fi
  done
  command -v lu-product-os-doctor >/dev/null 2>&1 \
    || warn "not on PATH (no writable /usr/local/bin or ~/.local/bin) — call it by absolute path in non-interactive shells"
fi

if ! git rev-parse --git-dir >/dev/null 2>&1; then
  fail "Not a git repository. Run 'git init' first (or cd into the project repo)."
  STATUS=none
else
  # ---------- 1. Remote ----------
  ORIGIN=$(git remote get-url origin 2>/dev/null || true)
  if [ -z "$ORIGIN" ]; then
    fail "No 'origin' remote — work here is unbacked-up and invisible to CI. Create a GitHub repo and push."
  else
    note "origin: $ORIGIN"
  fi

  OWNER=$(sed -E 's#(git@github\.com:|https://github\.com/)([^/]+)/.*#\2#' <<<"$ORIGIN" 2>/dev/null || true)
  CENTRAL="${LU_PRODUCT_OS_REPO:-${OWNER:-OWNER}/lu-product-os}"
  DEFAULT_BRANCH=$(gh repo view --json defaultBranchRef --jq .defaultBranchRef.name 2>/dev/null || echo main)
  NWO=$(gh repo view --json nameWithOwner --jq .nameWithOwner 2>/dev/null || true)

  # ---------- 2. verify script ----------
  VERIFY=scripts/lu-product-os-verify
  if [ -x "$VERIFY" ]; then
    note "$VERIFY exists and is executable"
  elif $QUICK; then
    warn "$VERIFY missing — CI gate G1 cannot run"
  else
    mkdir -p scripts
    {
      echo '#!/usr/bin/env bash'
      echo '# lu-product-os-verify — this project'\''s full quality gates in one command.'
      echo '# CI runs exactly this script (gate G1). Keep it the single source of truth.'
      echo 'set -euo pipefail'
      echo ''
      if [ -f bun.lock ] || [ -f bun.lockb ]; then
        echo 'curl -fsSL https://bun.sh/install | bash >/dev/null 2>&1 || true'
        echo 'export PATH="$HOME/.bun/bin:$PATH"'
        echo 'bun install --frozen-lockfile'
        echo 'bun run typecheck   # TODO: confirm script names in package.json'
        echo 'bun run lint'
        echo 'bun test'
        echo 'bun run build'
      elif [ -f package.json ]; then
        echo 'npm ci'
        echo 'npx tsc --noEmit                       # TODO: adjust to this project'
        echo 'npm run lint --if-present'
        echo 'npm test --if-present'
        echo 'npm run build --if-present'
      elif [ -f composer.json ]; then
        echo 'composer install --no-interaction --prefer-dist'
        echo './vendor/bin/pint --test               # TODO: adjust to this project'
        echo 'php artisan test'
      else
        echo 'echo "TODO: add this project'\''s typecheck/lint/test/build commands" && exit 1'
      fi
    } >"$VERIFY"
    chmod +x "$VERIFY"
    fixed "$VERIFY scaffolded from detected stack — review the TODO lines before relying on it"
  fi

  # ---------- 3. CI caller workflow ----------
  CALLER=.github/workflows/lu-product-os-ci.yml
  if [ -f "$CALLER" ]; then
    note "$CALLER present"
  elif $QUICK; then
    warn "$CALLER missing — no CI runs on PRs"
  else
    mkdir -p .github/workflows
    cat >"$CALLER" <<EOF
# lu-product-os CI caller — the real workflow lives in ${CENTRAL} and
# propagates to every project. Do not add steps here; improve the central one.
name: ci
on:
  pull_request:
  push:
    branches: [${DEFAULT_BRANCH}]
jobs:
  lu-product-os:
    uses: ${CENTRAL}/.github/workflows/lu-product-os-ci.yml@main
    secrets: inherit
    permissions:
      contents: read
      pull-requests: read
      issues: read
EOF
    fixed "$CALLER created (calls ${CENTRAL})"
  fi

  # ---------- 4. PR template ----------
  PRT=.github/pull_request_template.md
  if [ -f "$PRT" ]; then
    note "$PRT present"
  elif gh api "repos/${OWNER}/.github/contents/.github/pull_request_template.md" >/dev/null 2>&1; then
    note "org-level default PR template found (${OWNER}/.github)"
  elif $QUICK; then
    warn "no PR template (repo or org) — gate G2 content won't be prompted"
  else
    mkdir -p .github
    if gh api "repos/${CENTRAL}/contents/templates/lu-product-os-pull-request-template.md" \
        --jq .content 2>/dev/null | base64 -d >"$PRT" 2>/dev/null && [ -s "$PRT" ]; then
      fixed "$PRT installed from ${CENTRAL}"
    else
      rm -f "$PRT"
      warn "could not fetch PR template from ${CENTRAL} — install it manually from templates/"
    fi
  fi

  # ---------- 5. Agent entry files ----------
  if [ -f AGENTS.md ] || [ -f CLAUDE.md ]; then
    ENTRY=$( [ -f CLAUDE.md ] && echo CLAUDE.md || echo AGENTS.md )
    note "$ENTRY present"
    grep -qiE '^\s*-?\s*\*{0,2}profile:?\*{0,2}\s*(prototype|standard|production)' "$ENTRY" 2>/dev/null \
      || warn "$ENTRY has no 'profile:' line (prototype|standard|production) — tiers/gates can't calibrate"
    grep -qiE '^\s*-?\s*\*{0,2}verifier:?\*{0,2}\s*\S' "$ENTRY" 2>/dev/null \
      || warn "$ENTRY has no 'verifier:' line — full-tier changes can't request independent verification"
  else
    warn "no CLAUDE.md or AGENTS.md — agents have no project entry point (see templates/lu-product-os-AGENTS-stub.md in ${CENTRAL})"
  fi

  # ---------- 5b. Branch flow ----------
  # Repos that promote through an integration branch (feature -> staging ->
  # main) must declare it, or agents branch from the wrong trunk and
  # promotion PRs get re-verified into structural red.
  FLOWLINE=$(grep -hiE '^\s*-?\s*\*{0,2}flow:?\*{0,2}\s*\S' CLAUDE.md AGENTS.md 2>/dev/null | head -1 \
    | sed -E 's/^[[:space:]*-]*[Ff][Ll][Oo][Ww]:?\**[[:space:]]*//' || true)
  if [ -n "$FLOWLINE" ]; then
    note "flow: ${FLOWLINE} — branch from (and PR into) the first integration branch; promotion PRs are gated on constituent-PR greenness only"
  elif git ls-remote --exit-code --heads origin staging >/dev/null 2>&1; then
    warn "origin has a 'staging' branch but no 'flow:' line in CLAUDE.md/AGENTS.md — declare e.g. 'flow: feature -> staging -> main' or agents will branch from the wrong trunk and promotion PRs will fail pr-check"
  fi

  # ---------- 6. Branch protection ----------
  if [ -n "$NWO" ]; then
    RULES=$(gh api "repos/${NWO}/rules/branches/${DEFAULT_BRANCH}" --jq 'length' 2>/dev/null || echo "")
    PROT=$(gh api "repos/${NWO}/branches/${DEFAULT_BRANCH}/protection" --jq '.required_status_checks.contexts | length' 2>/dev/null || echo "")
    # On an HTTP error (e.g. 403: private repo on a free plan) gh api dumps the
    # error JSON to stdout, so RULES/PROT hold a JSON body, not a count — which
    # made the test below report protection as active when none exists. Keep
    # only clean numeric values; anything else means "could not confirm".
    case "$RULES" in ''|*[!0-9]*) RULES="" ;; esac
    case "$PROT"  in ''|*[!0-9]*) PROT=""  ;; esac
    if [ -n "$RULES" ] && [ "$RULES" -gt 0 ] || [ -n "$PROT" ]; then
      note "branch rules/protection active on ${DEFAULT_BRANCH}"
    elif $QUICK; then
      if [ -f "$CALLER" ]; then
        warn "no branch protection on ${DEFAULT_BRANCH} — free-plan DETECTION MODE: merges are not blocked; main-guard (CI) alerts on unverified merges after the fact"
      else
        fail "no branch protection AND no CI caller on ${DEFAULT_BRANCH} — gates are neither enforced nor detected"
      fi
    else
      if gh api -X PUT "repos/${NWO}/branches/${DEFAULT_BRANCH}/protection" \
          --input - >/dev/null 2>&1 <<'JSON'
{
  "required_status_checks": { "strict": true, "contexts": ["lu-product-os / verify", "lu-product-os / pr-check"] },
  "enforce_admins": true,
  "required_pull_request_reviews": null,
  "restrictions": null,
  "allow_force_pushes": false,
  "allow_deletions": false
}
JSON
      then
        fixed "branch protection set on ${DEFAULT_BRANCH} (PR required; checks: verify, pr-check; applies to admins)"
      else
        if [ -f "$CALLER" ]; then
          warn "could not set branch protection (private repo on free plan?) — running in DETECTION MODE: main-guard (CI) alerts on unverified merges but cannot block them. To hard-enforce: upgrade plan, make repo public, or configure an org ruleset."
        else
          fail "could not set branch protection and no CI caller present — nothing enforces OR detects. Re-run doctor (non-quick) to scaffold CI first."
        fi
      fi
    fi
  fi

  # ---------- 6aa. Gate credibility — no tolerated red ----------
  # A check that is red on every run makes every merge button amber and trains
  # everyone to ignore red — the most corrosive state an outcome-gated process
  # can be in. Quick mode looks at the default-branch tip (one API call); full
  # mode also catches case-duplicate workflow names, which break
  # `gh run rerun --workflow <name>` and cause stale check reports.
  if [ -n "$NWO" ]; then
    RED=$(gh api "repos/${NWO}/commits/${DEFAULT_BRANCH}/check-runs" \
      --jq '[.check_runs[] | select(.conclusion=="failure") | .name] | unique | join(", ")' 2>/dev/null || true)
    if [ -n "$RED" ]; then
      warn "red check(s) on ${DEFAULT_BRANCH} tip: [${RED}] — if chronic, every merge shows amber and gates lose meaning. Fix the check or delete it; never tolerate standing red. (This also blocks/complicates merges: GitHub reports UNSTABLE.)"
    fi
    if ! $QUICK; then
      DUPWF=$(gh api "repos/${NWO}/actions/workflows" \
        --jq '[.workflows[].name | ascii_downcase] | group_by(.) | map(select(length>1) | .[0]) | join(", ")' 2>/dev/null || true)
      [ -n "$DUPWF" ] && warn "workflow names differing only in case: [${DUPWF}] — 'gh run rerun --workflow <name>' matches nothing or the wrong one; rename or delete one"
    fi
  fi

  # ---------- 6b. Codebase docs freshness (stamp check) ----------
  # Documentor Update stamps the code commit it regenerated against. Comparing
  # that stamp to the latest CODE commit (docs/plan/md excluded) makes doc
  # staleness detectable in one line — so builds don't need a pre-build
  # Validate pass, and a skipped regeneration can never be silent.
  DOCS_DIR=0-documentation-codebase
  STAMP_FILE="$DOCS_DIR/.docs-fresh-sha"
  if [ -d "$DOCS_DIR" ]; then
    LATEST_CODE=$(git log -1 --format=%H -- . ":(exclude)$DOCS_DIR" ':(exclude)0-plan' ':(exclude)0-wip' ':(exclude)*.md' 2>/dev/null || true)
    STAMP=$(head -1 "$STAMP_FILE" 2>/dev/null || true)
    if [ -z "$STAMP" ]; then
      warn "codebase docs have no freshness stamp ($STAMP_FILE) — run Documentor Update once to create it; until then freshness is unknown"
    elif [ -n "$LATEST_CODE" ] && [ "$STAMP" != "$LATEST_CODE" ]; then
      warn "codebase docs STALE — stamp ${STAMP:0:7} != latest code commit ${LATEST_CODE:0:7}. Run Documentor Validate/Update before building."
    else
      note "codebase docs fresh (stamp ${STAMP:0:7} matches latest code commit)"
    fi
  fi

  # ---------- 7. Live infrastructure (full mode only) ----------
  # Documented infra rots and becomes an accident vector; verify it live instead.
  # Runs ONLY in full mode — --quick must stay fast for session startup.
  if ! $QUICK; then
    # Railway
    if [ -f railway.json ] || [ -f railway.toml ] || [ -n "${RAILWAY_ENVIRONMENT_NAME:-}" ]; then
      if ! command -v railway >/dev/null; then
        warn "Railway config detected but railway CLI not installed — live infra cannot be verified (npm i -g @railway/cli)"
      elif ! railway whoami >/dev/null 2>&1; then
        warn "railway CLI not authenticated — run 'railway login' (agents cannot derive hosts/services until then)"
      else
        RSTATUS=$(railway status --json 2>/dev/null || true)
        if [ -z "$RSTATUS" ]; then
          fail "railway CLI authenticated but no project linked here — run 'railway link'. Proxy hosts and service lists cannot be derived; do NOT fall back to documented values."
        else
          # TODO: confirm these jq paths against your installed railway CLI version
          RPROJ=$(jq -r '.name // empty' <<<"$RSTATUS" 2>/dev/null)
          RENV=$(jq -r '.environment.name // .environment // empty' <<<"$RSTATUS" 2>/dev/null)
          RSVCS=$(jq -r '[.services[]?.name // empty] | join(", ")' <<<"$RSTATUS" 2>/dev/null)
          note "railway linked: project=${RPROJ:-?} env=${RENV:-?} services=[${RSVCS:-unresolved}]"
          if [ -n "${RAILWAY_ENVIRONMENT_NAME:-}" ] && [ -n "$RENV" ] && [ "$RAILWAY_ENVIRONMENT_NAME" != "$RENV" ]; then
            fail "RAILWAY_ENVIRONMENT_NAME='$RAILWAY_ENVIRONMENT_NAME' but linked environment is '$RENV' — derived proxy hosts will point at the WRONG environment"
          fi
          [ -n "$RENV" ] || warn "railway environment unresolved — hosts derived from RAILWAY_ENVIRONMENT_NAME cannot be trusted"
        fi
      fi
    fi
    # Vercel
    if [ -f vercel.json ] || [ -d .vercel ]; then
      if ! command -v vercel >/dev/null; then
        warn "Vercel config detected but vercel CLI not installed — live infra cannot be verified"
      elif [ ! -f .vercel/project.json ]; then
        warn "Vercel config present but project not linked here — run 'vercel link'"
      else
        note "vercel linked: project=$(jq -r '.projectId // "?"' .vercel/project.json 2>/dev/null)"
      fi
    fi
  fi
fi

# ---------- Banner + report ----------
case $STATUS_WORST in
  0) BANNER="Machinery: full" ;;
  1) BANNER="Machinery: partial — see warnings" ;;
  2) BANNER="Machinery: none/broken — gates are NOT enforced; agents run in prompt mode" ;;
esac

echo ""
echo "${BOLD}lu-product-os doctor — $(basename "$(pwd)")${RESET}"
printf '  %s\n' "${REPORT[@]}"
echo ""
echo "${BOLD}${BANNER}${RESET}"
$QUICK || echo "Next: open a trivial canary PR and confirm the checks run AND block before real work."
exit $([ $STATUS_WORST -eq 2 ] && echo 1 || echo 0)
