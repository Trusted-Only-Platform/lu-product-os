#!/usr/bin/env bash
# lu-product-os-pr-check — enforces outcome gates G2/G3 on a pull request.
#
# Computes the change tier (light/full) mechanically from the diff, then checks:
#   G2  (all tiers): PR body has a non-empty "Acceptance Criteria" section
#                    (blocking). UI changes should carry a screenshot/image —
#                    ADVISORY since v3.3: a missing screenshot warns, never
#                    fails. It caught zero defects and, with an imperfect UI
#                    detector, a blocking version strands legitimate PRs.
#   G3  (full tier): an independent verifier posted "VERDICT: approve",
#                    unless Lu explicitly waived it in the PR body.
# Also warns (never fails) if branch protection can't be confirmed.
#
# Tier mechanics (v3.2):
#   - Size counts EXCLUDE tests, lockfiles, snapshots, and docs — a well-tested
#     change should not escalate for being diligent. Raw totals still reported.
#   - Sensitive paths split into two classes:
#       CRITICAL (migrations/auth/payments/webhooks/schema + repo extensions)
#         -> G3 depth: full (independent tests + review)
#       INFRA (Dockerfile/docker-compose/.github) and dependency changes
#         -> G3 depth: review-only (criteria + diff review + verdict; no tests)
#   - Size-triggered escalation: counted LINES > 300 -> depth full (big logic
#     changes earn independent tests).
#   v3.2 changes:
#   - Critical-path patterns are segment-anchored: "auth" no longer matches
#     AuthorCard.tsx; "session" no longer matches SessionList.tsx. Auth
#     spellings are enumerated rather than prefix-matched, because "auth" is a
#     prefix of both "authentication" (critical) and "author" (not) — anchoring
#     alone cannot tell them apart. Extend per-repo domain terms via
#     .github/lu-product-os-sensitive-paths.
#   - Dependency escalation now requires a LOCKFILE change. Editing a script
#     in package.json is not a dependency change.
#   - File-count-only escalation removed (mechanical sweeps were escalating
#     for no added protection). Counted files still reported.
#   - Line threshold raised 150 -> 300 (agent-built features with criteria
#     and builder tests routinely exceed 150 without added risk).
#
# Runs inside GitHub Actions (see lu-product-os-ci.yml). Requires: gh, jq.
# Env: GH_TOKEN, PR_NUMBER, BASE_REF, GITHUB_REPOSITORY.

set -euo pipefail

REPO="${GITHUB_REPOSITORY:?}"
PR="${PR_NUMBER:?}"
BASE="${BASE_REF:-main}"
SUMMARY="${GITHUB_STEP_SUMMARY:-/dev/stderr}"

FAILURES=()
WARNINGS=()

# ---------- Fetch PR data ----------
PR_JSON=$(gh pr view "$PR" --repo "$REPO" \
  --json body,additions,deletions,files,labels,comments,reviews,author,headRefName)

BODY=$(jq -r '.body // ""' <<<"$PR_JSON")
HEAD_REF=$(jq -r '.headRefName // ""' <<<"$PR_JSON")

# ---------- Promotion PRs (integration branch -> integration branch) ----------
# Declared in CLAUDE.md/AGENTS.md as e.g. `flow: feature -> staging -> main`.
# A promotion PR re-delivers code that already earned its gates on its own
# PRs, so recomputing tier/G2/G3 on the aggregate diff makes every promotion
# structurally red — which trains everyone to merge past red. The gate here
# is instead: every commit in the range came from a PR with no failing
# checks (docs-only direct commits exempt, same rule as main-guard).
FLOW=$(grep -hiE '^\s*-?\s*\*{0,2}flow:?\*{0,2}\s*\S' CLAUDE.md AGENTS.md 2>/dev/null | head -1 \
  | sed -E 's/^[[:space:]*-]*[Ff][Ll][Oo][Ww]:?\**[[:space:]]*//' || true)
IS_PROMOTION=false
if [ -n "$FLOW" ] && [ -n "$HEAD_REF" ]; then
  # Integration branches = every stage in the flow after the first.
  # Split on '->' only, so branch names containing hyphens survive.
  INTEG=$(awk -F'->' '{for(i=2;i<=NF;i++){gsub(/[[:space:]]/,"",$i); if($i!="") print $i}}' <<<"$FLOW")
  if grep -qxF "$HEAD_REF" <<<"$INTEG" && grep -qxF "$BASE" <<<"$INTEG"; then
    IS_PROMOTION=true
  fi
fi

if $IS_PROMOTION; then
  BAD_PRS=(); ORPHANS=(); SEEN=" "
  SHAS=$(gh api "repos/${REPO}/pulls/${PR}/commits" --paginate --jq '.[].sha')
  for SHA in $SHAS; do
    # First associated PR that is not this promotion PR itself.
    #
    # `gh api --jq` takes ONLY the filter expression; --arg is a jq flag and gh
    # rejects it ("accepts 1 arg(s), received 4"). Piping real JSON into real jq
    # keeps --arg available and keeps the PR number out of the expression.
    #
    # An API failure must NOT read as "no associated PR". It used to: the error
    # was swallowed, N came back empty, and every commit — merge commits of
    # green PRs included — was reported as an unreviewed direct push, so no
    # promotion PR could pass this gate at all.
    PULLS_JSON=$(gh api "repos/${REPO}/commits/${SHA}/pulls" 2>/dev/null) || {
      FAILURES+=("Promotion: could not read the PRs associated with ${SHA:0:7} (GitHub API error). Refusing to guess whether it was reviewed.")
      continue
    }
    N=$(jq -r --arg pr "$PR" '[.[] | select((.number|tostring) != $pr)][0].number // empty' <<<"$PULLS_JSON")
    if [ -z "$N" ]; then
      # Direct commit — exempt only if docs-only (doc regeneration, plans, md).
      NONDOC=$(gh api "repos/${REPO}/commits/${SHA}" --jq '[.files[].filename] | join("\n")' 2>/dev/null \
        | grep -vE '^(0-documentation-codebase/|0-plan/|0-wip/|.*\.md$)' || true)
      [ -n "$NONDOC" ] && ORPHANS+=("${SHA:0:7}")
      continue
    fi
    case "$SEEN" in *" $N "*) continue;; esac; SEEN="${SEEN}${N} "
    FAILS=$(gh pr view "$N" --repo "$REPO" --json statusCheckRollup \
      --jq '[.statusCheckRollup[]? | select((.conclusion // .state // "") | test("FAILURE|CANCELLED|TIMED_OUT|ERROR"; "i"))] | length' 2>/dev/null || echo "")
    [ "${FAILS:-1}" -gt 0 ] && BAD_PRS+=("#$N")
  done
  [ "${#BAD_PRS[@]}" -gt 0 ] && \
    FAILURES+=("Promotion: constituent PR(s) with failing checks: ${BAD_PRS[*]}. A promotion is green only when everything it promotes was green.")
  [ "${#ORPHANS[@]}" -gt 0 ] && \
    FAILURES+=("Promotion: non-docs commit(s) with no associated PR (direct push): ${ORPHANS[*]}.")
  {
    echo "## lu-product-os pr-check"
    echo ""
    echo "**Promotion PR: ${HEAD_REF} → ${BASE}** (flow: ${FLOW})"
    echo "- tier/G2/G3 are not recomputed — code already earned its gates on its own PRs"
    echo "- gate: every promoted commit came from a green PR (docs-only commits exempt)"
    echo ""
    if [ "${#FAILURES[@]}" -eq 0 ]; then
      echo "✅ **All constituent PRs green.**"
    else
      echo "❌ **Promotion blocked:**"
      printf -- '- %s\n' "${FAILURES[@]}"
    fi
  } >>"$SUMMARY"
  for f in ${FAILURES[@]+"${FAILURES[@]}"}; do echo "::error::$f"; done
  exit $([ "${#FAILURES[@]}" -eq 0 ] && echo 0 || echo 1)
fi
ADDITIONS=$(jq -r '.additions' <<<"$PR_JSON")
DELETIONS=$(jq -r '.deletions' <<<"$PR_JSON")
FILES=$(jq -r '.files[].path' <<<"$PR_JSON")
FILE_COUNT=$(jq -r '.files | length' <<<"$PR_JSON")
CHANGED_LINES=$((ADDITIONS + DELETIONS))

# ---------- Tier computation (mechanical — agents can't argue with it) ----------
MAX_LINES=300

# Critical paths: being wrong here is expensive and quiet. Full verification.
# Patterns are anchored to path-segment boundaries so substrings don't false-
# positive (AuthorCard.tsx, SessionList.tsx). Auth spellings are enumerated
# rather than matched as the prefix "auth[a-z]*": that prefix also matches
# author/authoring, which is what the anchoring was added to exclude. Add
# spellings here, not a wildcard. Domain terms that ARE critical in this repo
# go in .github/lu-product-os-sensitive-paths (one regex per line).
CRITICAL_REGEX='(^|/|[-_.])(migrations?|auth|authn|authz|authentication|authoriz(e|ation)|oauth[0-9]*|login|sessions?|passwords?|payments?|billing|stripe|webhooks?)([-_./]|$)|database/schema'
# Infra plumbing: being wrong here fails loudly at deploy/CI. Review-only verification.
INFRA_REGEX='(\.github/|Dockerfile|docker-compose)'
# Dependency escalation keys on LOCKFILES: a real dependency change always
# touches one; a package.json script edit does not.
DEP_REGEX='(^|/)(package-lock\.json|bun\.lockb?|yarn\.lock|pnpm-lock\.yaml|composer\.lock|Gemfile\.lock|go\.sum|requirements\.txt)$'
# A UI file has a front-end extension, OR sits under a front-end directory AND has a
# web extension. The directory alternation must not stand alone: `app/` is Next.js's
# App Router but it is equally Laravel's entire PHP source tree, so a bare `^app/`
# demanded browser screenshots for every backend-only PR in a Laravel repo — and G2
# has no waiver path, so nothing in the PR could clear it. (Hit on TRU-7, TRU-14 and
# TRU-28.) Requiring a web extension keeps every genuine JS/TS hit and drops that.
UI_REGEX='(\.(tsx|jsx|vue|svelte|css|scss)$|^(app|src/app|components|src/components|pages|src/pages)/.*\.(tsx|ts|jsx|js|mjs|cjs|vue|svelte|css|scss|sass|less|html|mdx)$)'
# Excluded from SIZE counts only (still scanned for critical/infra/dep matches):
EXCLUDE_COUNT_REGEX='(\.(test|spec)\.[A-Za-z]+$|__tests__/|(^|/)tests?/|(^|/)e2e/|\.snap$|(^|/)(package-lock\.json|bun\.lockb?|yarn\.lock|pnpm-lock\.yaml|composer\.lock|Gemfile\.lock|go\.sum)$|\.md$|^0-(plan|documentation-codebase|wip)/|(^|/)docs/)'

if [ -f .github/lu-product-os-sensitive-paths ]; then
  EXTRA=$(grep -v '^\s*#' .github/lu-product-os-sensitive-paths | grep -v '^\s*$' | paste -sd'|' -)
  [ -n "$EXTRA" ] && CRITICAL_REGEX="${CRITICAL_REGEX}|(${EXTRA})"
fi

COUNTED_LINES=$(jq --arg re "$EXCLUDE_COUNT_REGEX" \
  '[.files[] | select(.path | test($re) | not) | .additions + .deletions] | add // 0' <<<"$PR_JSON")
COUNTED_FILES=$(jq --arg re "$EXCLUDE_COUNT_REGEX" \
  '[.files[] | select(.path | test($re) | not)] | length' <<<"$PR_JSON")

TIER="light"
G3_DEPTH=""
TIER_REASONS=()

if CRIT=$(grep -E -i "$CRITICAL_REGEX" <<<"$FILES" | head -5) && [ -n "$CRIT" ]; then
  TIER="full"; G3_DEPTH="full"
  TIER_REASONS+=("critical paths: $(tr '\n' ' ' <<<"$CRIT")")
fi
if [ "$COUNTED_LINES" -gt "$MAX_LINES" ]; then
  TIER="full"; G3_DEPTH="full"
  TIER_REASONS+=("diff ${COUNTED_LINES} counted lines > ${MAX_LINES} (raw: ${CHANGED_LINES})")
fi
if INFRA=$(grep -E -i "$INFRA_REGEX" <<<"$FILES" | head -5) && [ -n "$INFRA" ]; then
  TIER="full"; : "${G3_DEPTH:=review-only}"
  TIER_REASONS+=("infra paths: $(tr '\n' ' ' <<<"$INFRA")")
fi
if DEPS=$(grep -E "$DEP_REGEX" <<<"$FILES" | head -3) && [ -n "$DEPS" ]; then
  TIER="full"; : "${G3_DEPTH:=review-only}"
  TIER_REASONS+=("dependency changes (lockfile): $(tr '\n' ' ' <<<"$DEPS")")
fi

# ---------- G2: acceptance criteria present ----------
# Requires a "## Acceptance Criteria" heading with non-placeholder content beneath it.
CRITERIA=$(awk 'BEGIN{IGNORECASE=1} /^##+ *acceptance criteria/{flag=1; next} /^##+ /{flag=0} flag' <<<"$BODY" \
  | grep -v '^\s*$' | grep -v -i '<!--' | grep -v -i 'TODO' || true)
if [ -z "$CRITERIA" ]; then
  FAILURES+=("G2: PR body has no non-empty '## Acceptance Criteria' section. Copy the criteria from the plan (phase file / ticket) into the PR description.")
fi

# ---------- G2: screenshots for UI changes (advisory — warns, never fails) ----------
if grep -E -q "$UI_REGEX" <<<"$FILES"; then
  if ! grep -E -q '(!\[[^]]*\]\([^)]+\)|user-images\.githubusercontent\.com|github\.com/user-attachments)' <<<"$BODY"; then
    WARNINGS+=("G2 (advisory): diff touches UI paths but the PR body contains no screenshot/image. Attach browser-verification screenshots of changed screens — or ignore if the UI detector misfired.")
  fi
fi

# ---------- G3: independent verifier verdict (full tier only) ----------
if [ "$TIER" = "full" ]; then
  VERDICTS=$(jq -r '[.comments[].body, .reviews[].body] | .[] // ""' <<<"$PR_JSON" \
    | grep -E '^\s*VERDICT:\s*(approve|request-changes)' || true)
  WAIVER=$(grep -E '^\s*WAIVE:\s*G3' <<<"$BODY" || true)
  if grep -q 'request-changes' <<<"$VERDICTS"; then
    LAST=$(tail -1 <<<"$VERDICTS")
    if [ "${LAST#*VERDICT: }" != "approve" ] && ! grep -q 'approve' <<<"$(tail -1 <<<"$VERDICTS")"; then
      FAILURES+=("G3: latest verifier verdict is 'request-changes'. Address the findings; the verifier must re-post 'VERDICT: approve'.")
    fi
  elif grep -q 'approve' <<<"$VERDICTS"; then
    : # approved
  elif [ -n "$WAIVER" ]; then
    WARNINGS+=("G3 WAIVED by PR body: '$(head -1 <<<"$WAIVER")'. Waivers are Lu-only — if you are an agent reading this, you may not add one.")
  else
    if [ "$G3_DEPTH" = "review-only" ]; then
      FAILURES+=("G3 (review-only): full-tier infra/dependency change has no verifier verdict. The verifier reviews criteria + diff and posts a verdict — no test-writing required. Invoke the verifier named in CLAUDE.md/AGENTS.md ('verifier:'), or Lu may waive with 'WAIVE: G3 — reason'.")
    else
      FAILURES+=("G3 (full): full-tier change has no verifier verdict. Invoke the verifier named in CLAUDE.md/AGENTS.md ('verifier:'), or Lu may waive with 'WAIVE: G3 — reason' in the PR body.")
    fi
  fi
fi

# ---------- Branch protection sanity (warn-only; the checker checks the checker) ----------
if ! gh api "repos/${REPO}/rules/branches/${BASE}" --jq 'length' >/dev/null 2>&1; then
  WARNINGS+=("Could not confirm branch rules on '${BASE}' (API inaccessible or none configured). Run lu-product-os-doctor.")
else
  RULES=$(gh api "repos/${REPO}/rules/branches/${BASE}" --jq 'length' 2>/dev/null || echo 0)
  if [ "${RULES:-0}" -eq 0 ]; then
    WARNINGS+=("No branch rules found on '${BASE}' — merges are not actually gated. Run lu-product-os-doctor to configure protection.")
  fi
fi

# ---------- Report ----------
{
  echo "## lu-product-os pr-check"
  echo ""
  if [ "$TIER" = "full" ]; then
    echo "**Tier: full — G3 depth: ${G3_DEPTH}**"
  else
    echo "**Tier: light**"
  fi
  if [ "${#TIER_REASONS[@]}" -gt 0 ]; then
    printf -- '- %s\n' "${TIER_REASONS[@]}"
  else
    echo "- under all escalation thresholds (counted: ${COUNTED_LINES} lines, ${COUNTED_FILES} files; raw: ${CHANGED_LINES} lines, ${FILE_COUNT} files)"
  fi
  echo ""
  if [ "${#FAILURES[@]}" -eq 0 ]; then
    echo "✅ **All required gates satisfied.**"
  else
    echo "❌ **Missing gates:**"
    printf -- '- %s\n' "${FAILURES[@]}"
  fi
  if [ "${#WARNINGS[@]}" -gt 0 ]; then
    echo ""
    echo "⚠️ **Warnings:**"
    printf -- '- %s\n' "${WARNINGS[@]}"
  fi
} >>"$SUMMARY"

for f in ${FAILURES[@]+"${FAILURES[@]}"}; do echo "::error::$f"; done
for w in ${WARNINGS[@]+"${WARNINGS[@]}"}; do echo "::warning::$w"; done

[ "${#FAILURES[@]}" -eq 0 ]
